{
  "method": "consistency",
  "model": "resnet18_cifar",
  "dataset": "cifar10",
  "epochs": 100,
  "batch_size": 64,
  "optimizer": "sgd",
  "learning_rate": 0.1,
  "momentum": 0.9,
  "weight_decay": 0.0005,
  "scheduler": "cosine_annealing",
  "corruption_severity": 2,
  "lambda_kl": 2.0,
  "warmup_epochs": 10
}
